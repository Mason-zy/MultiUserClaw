# ============================================================
# Nanobot 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#
# 本文件由 start_local.py（本地开发）和 docker-compose.yml（Docker 部署）共同读取。
# start_local.py 会自动将 *_API_KEY / *_API_BASE 变量注入 PLATFORM_ 前缀传给 Gateway。
# ============================================================


# ── LLM 服务商 API Key ──────────────────────────────────────
# 至少配置一个 API Key，否则无法调用大模型。
# 只需填写你实际使用的服务商，其余留空即可。
#
# 模型命名规则（DEFAULT_MODEL 和前端选择模型时通用）：
#   前缀/模型名  — 显式指定供应商，如 "dashscope/qwen-turbo"
#   纯模型名     — 按关键词自动匹配，如 "claude-sonnet-4-5" 自动走 Anthropic
#
# ┌─────────────┬───────────────────────────────────────────────┐
# │ 前缀        │ 示例                                          │
# ├─────────────┼───────────────────────────────────────────────┤
# │ claude/     │ claude/claude-sonnet-4-5                      │
# │ openai/     │ openai/gpt-5.2               │
# │ deepseek/   │ deepseek/deepseek-chat, deepseek/deepseek-reasoner │
# │ dashscope/  │ dashscope/qwen3-coder-plus, dashscope/qwen-turbo   │
# │ kimi/       │ kimi/kimi-k2.5, kimi/moonshot-v1-128k        │
# │ zhipu/      │ zhipu/glm-4-flash, zhipu/glm-4              │
# │ doubao/     │ doubao/doubao-pro-256k                       │
# │ aihubmix/   │ aihubmix/claude-sonnet-4-5                   │
# │ evolink/    │ evolink/gpt-5.2, evolink/deepseek-chat        │
# │ vllm/       │ vllm/Qwen2.5-7B-Instruct                    │
# │ (无前缀)    │ claude-sonnet-4-5 → 自动匹配 Anthropic       │
# │ (无前缀)    │ gpt-4o → 自动匹配 OpenAI                     │
# └─────────────┴───────────────────────────────────────────────┘
# 使用阿里云上的Minimax模型
# DEFAULT_MODEL=dashscope/MiniMax/MiniMax-M2.7


# Anthropic (Claude 系列)
# 关键词匹配: 模型名含 "claude" 自动路由
# 示例: claude-sonnet-4-5, claude/claude-opus-4-5
ANTHROPIC_API_KEY=

# OpenAI (GPT / o 系列)
# 关键词匹配: 模型名含 "gpt"、"o1"、"o3"、"o4" 自动路由
# 示例: gpt-4o, openai/gpt-4o-mini, openai/o3-mini
OPENAI_API_KEY=
# 如果用的不是openai的
# OPENAI_API_BASE=xx

# DeepSeek
# 关键词匹配: 模型名含 "deepseek" 自动路由
# 示例: deepseek/deepseek-chat, deepseek/deepseek-reasoner
DEEPSEEK_API_KEY=

# 阿里云 DashScope (通义千问 Qwen 系列)
# 关键词匹配: 模型名含 "qwen" 自动路由
# 示例: dashscope/qwen3-coder-plus, dashscope/qwen-turbo, qwen-max
DASHSCOPE_API_KEY=

# Moonshot / Kimi
# 关键词匹配: 模型名含 "kimi" 或 "moonshot" 自动路由
# 示例: kimi/kimi-k2.5, kimi/moonshot-v1-128k
# 注意: kimi-k2.5 等模型不支持自定义 temperature，系统会自动跳过该参数
KIMI_API_KEY=

# 智谱 AI (GLM 系列)
# 关键词匹配: 模型名含 "glm" 自动路由
# 示例: zhipu/glm-4-flash, zhipu/glm-4, glm-4-flash
ZHIPU_API_KEY=

# 豆包 (字节跳动 / 火山引擎)
# 关键词匹配: 模型名含 "doubao" 自动路由
# 示例: doubao/doubao-pro-256k, doubao/doubao-lite-128k
# API Base: https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=

# AiHubMix (聚合代理，可访问多家模型)
# 关键词匹配: 模型名含 "aihubmix" 自动路由
# 示例: aihubmix/claude-sonnet-4-5, aihubmix/gpt-4o
AIHUBMIX_API_KEY=

# Evolink (聚合代理，可访问多家模型，OpenAI 兼容)
# 关键词匹配: 模型名含 "evolink" 自动路由
# 示例: evolink/gpt-5.2, evolink/deepseek-chat
EVOLINK_API_KEY=

# OpenRouter (聚合代理，作为最后兜底)
# 当模型名匹配不到上述任何 provider 时，自动走 OpenRouter
# 示例: openrouter/anthropic/claude-sonnet-4-5
OPENROUTER_API_KEY=


# ── 自部署 / 本地模型 (vLLM) ─────────────────────────────────
# 如果你用 vLLM 部署了本地模型，配置以下两项。
# API Key 可以填任意非空字符串（vLLM 默认不校验 key）。
#
# 路由规则:
#   1. 使用 "vllm/" 前缀显式指定 → vllm/Qwen2.5-7B-Instruct
#   2. 模型名匹配不到任何云端 provider 时，自动作为兜底
#
# 启动 vLLM 示例：
#   vllm serve /data/models/Qwen2.5-7B-Instruct \
#     --served-model-name Qwen2.5-7B-Instruct \
#     --enable-auto-tool-choice --tool-call-parser hermes \
#     --port 8000
HOSTED_VLLM_API_KEY=
HOSTED_VLLM_API_BASE=
# 示例：
# HOSTED_VLLM_API_KEY=dummy
# HOSTED_VLLM_API_BASE=http://localhost:8000/v1


# ── 默认模型 ─────────────────────────────────────────────────
# 新用户容器的默认模型。推荐使用 "前缀/模型名" 格式明确指定 provider。
# 示例：
#   DEFAULT_MODEL=dashscope/qwen3-coder-plus    # 阿里云 Qwen
#   DEFAULT_MODEL=claude-sonnet-4-5              # Anthropic Claude
#   DEFAULT_MODEL=kimi/kimi-k2.5                 # Moonshot Kimi
#   DEFAULT_MODEL=vllm/Qwen2.5-7B-Instruct      # 本地 vLLM
#   DEFAULT_MODEL=openai/gpt-5.2                  # OpenAI
#   DEFAULT_MODEL=deepseek/deepseek-chat         # DeepSeek
DEFAULT_MODEL=dashscope/qwen3-coder-plus

# 平台代理模型输入能力（影响 platform-proxy 下模型是否可接收图片）
# text       = 仅文本模型
# text,image = 多模态模型（推荐，支持图片识别）
NANOBOT_PROXY__MODEL_INPUT=text,image

# MiniMax配置
MINIMAX_API_BASE=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=sk-xxx
DEFAULT_MODEL=minimax/MiniMax-M2.7
# 为提升回答完成速度，平台默认把 MiniMax-M2.7 路由到同族 highspeed 变体。
# 需要严格使用原始 MiniMax-M2.7 时改为 false。
MINIMAX_M27_USE_HIGHSPEED=true

# ── Runtime 后端选择 ─────────────────────────────────────────
# 默认只切底层 runtime 容器到 Hermes；对外 API 路径仍保持 /api/openclaw/*
# 和 /api/shared-openclaw/* 兼容。需要回滚时可显式改为 openclaw。
PLATFORM_DEDICATED_RUNTIME_BACKEND=hermes
PLATFORM_SHARED_RUNTIME_BACKEND=hermes
PLATFORM_HERMES_CONNECT_RETRIES=60
PLATFORM_HERMES_RETRY_DELAY_SECONDS=0.5
# Hermes API Server 默认只暴露 full-chain 医学调研需要的最小工具集：
# terminal 跑检索脚本，file 读写检索结果，skills 让模型显式查看技能说明。
# 需要纯问答测速可改为 none；需要完整 Hermes 工具面可改为 full。
PLATFORM_HERMES_API_TOOLSETS=terminal,file,skills
# Hermes API Server 默认关闭模型 reasoning/thinking，减少首个可见 token 前的等待。
# 需要更强推理时可改为 minimal/low/medium/high/xhigh；需要服务商默认值时留空。
PLATFORM_HERMES_REASONING_EFFORT=none
# 可选加速档位；支持的模型/供应商会映射到 service_tier=priority 或 speed=fast。
# 不确定供应商是否支持时保持空值。
PLATFORM_HERMES_SERVICE_TIER=
PLATFORM_HERMES_IMAGE=nanobot-hermes-agent:latest
PLATFORM_OPENCLAW_IMAGE=openclaw:latest
PLATFORM_SHARED_HERMES_URL=http://shared-openclaw:8080
PLATFORM_SHARED_HERMES_API_KEY=dev-hermes-bridge-key

# ── OpenClaw-RL / 训练轨迹采集 PoC ─────────────────────────────
# 默认关闭。开启后 gateway 会把脱敏后的 model_chat trace 写到本地 JSONL。
PLATFORM_TRAINING_TRACE_ENABLED=false
# 默认关闭。开启后暴露内部 trace 采集接口 POST /api/training/traces。
# 生产环境必须配置随机长 token，并通过 Authorization: Bearer <token> 调用。
PLATFORM_TRAINING_TRACE_INGEST_ENABLED=false
PLATFORM_TRAINING_TRACE_INGEST_TOKEN=
PLATFORM_TRAINING_TRACE_DIR=/app/.hermes/training_traces
PLATFORM_TRAINING_TRACE_HASH_SALT=

# ── 容器时区 ─────────────────────────────────────────────────
# 用户 runtime 容器（默认 hermes-user-*）默认时区，影响 Cron 表达式的解释
CONTAINER_TZ=Asia/Shanghai

# ── 管理员账号 ─────────────────────────────────────────────────
# 首次启动时自动创建的管理员账号（用于管理后台 http://host:3081）。
# 如果该用户名已存在，则跳过创建。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── 安全配置 ─────────────────────────────────────────────────
# JWT 签名密钥，用于用户认证 token 的签发与验证。
# 生产环境务必修改为随机强密钥！可用命令生成：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production

# 默认的git的skill market
NANOBOT_SKILLS_MARKETPLACE_REPO=https://github.com/johnson7788/collect_skills

PLATFORM_DEDICATED_RUNTIME_BACKEND=hermes
PLATFORM_SHARED_RUNTIME_BACKEND=hermes
