ARG DEBIAN_IMAGE=docker.m.daocloud.io/library/debian:13.4
FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source

FROM ${DEBIAN_IMAGE} AS runtime

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

# Use domestic mirror for apt
RUN sed -i 's|http://deb.debian.org|http://mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list.d/debian.sources && \
    sed -i 's|http://security.debian.org|http://mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list.d/debian.sources

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 python3-pip ripgrep ffmpeg gcc python3-dev libffi-dev procps git openssh-client gosu && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -u 10000 -m -d /opt/data hermes

COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

WORKDIR /opt/hermes

RUN git config --global --add url."https://github.com/".insteadOf "git@github.com:" && \
    git config --global --add url."https://github.com/".insteadOf "ssh://git@github.com/" && \
    git config --global --add url."https://github.com/".insteadOf "git+ssh://git@github.com/"

RUN npm config set fetch-retries 5 && \
    npm config set fetch-retry-mintimeout 20000 && \
    npm config set fetch-retry-maxtimeout 120000 && \
    npm config set registry https://registry.npmmirror.com

COPY --chown=hermes:hermes package.json package-lock.json ./
RUN npm install --prefer-offline --no-audit --no-fund && \
    npx playwright install --with-deps chromium --only-shell

COPY --chown=hermes:hermes scripts/whatsapp-bridge/package.json scripts/whatsapp-bridge/package-lock.json ./scripts/whatsapp-bridge/
RUN cd /opt/hermes/scripts/whatsapp-bridge && \
    npm install --prefer-offline --no-audit --no-fund

USER root
COPY --chown=hermes:hermes pyproject.toml requirements.txt ./
COPY --chown=hermes:hermes acp_adapter agent cron gateway hermes_cli plugins tools ./
COPY --chown=hermes:hermes batch_runner.py cli.py hermes_constants.py hermes_logging.py hermes_state.py hermes_time.py model_tools.py rl_cli.py run_agent.py setup.py toolset_distributions.py toolsets.py trajectory_compressor.py utils.py ./

RUN chown -R hermes:hermes /opt/hermes
USER hermes
RUN uv venv --seed /opt/hermes/.venv && \
    /opt/hermes/.venv/bin/pip install --no-cache-dir -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple setuptools wheel && \
    /opt/hermes/.venv/bin/pip install --no-build-isolation --no-cache-dir -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple -e ".[all]"

COPY --chown=hermes:hermes . /opt/hermes
# RUN npm cache clean --force
USER root
RUN chmod +x /opt/hermes/docker/entrypoint.sh

ENV HERMES_HOME=/opt/data
VOLUME [ "/opt/data" ]
ENTRYPOINT [ "/opt/hermes/docker/entrypoint.sh" ]

ENV API_SERVER_ENABLED=true
ENV API_SERVER_HOST=0.0.0.0
ENV API_SERVER_PORT=18080
ENV API_SERVER_KEY=dev-hermes-bridge-key
ENV GATEWAY_ALLOW_ALL_USERS=true

EXPOSE 18080

CMD ["gateway", "run"]
