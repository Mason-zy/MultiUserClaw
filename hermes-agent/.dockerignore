# Git
.git
.gitignore
.gitmodules

# Dependencies
node_modules
**/node_modules
.venv
**/.venv

# Built artifacts that are regenerated inside the image.  Excluded so local
# rebuilds on the developer's machine don't invalidate the npm-install layer
# that now depends on the full ui-tui/packages/hermes-ink/ tree being present.
ui-tui/dist/
ui-tui/packages/hermes-ink/dist/

# CI/CD
.github

# Environment files
.env

./*.md

# Only ship the `main` system agent template into the image. The other
# packaged agents are excluded so a brand-new user container syncs just
# `main` as the default profile (see entrypoint.sh sync_nanobot_packaged_agents,
# which copies every dir under deploy_copy/Agents/ to /opt/data/profiles/).
deploy_copy/Agents/manager/
deploy_copy/Agents/programmer/
deploy_copy/Agents/researcher/
deploy_copy/Agents/hr/
deploy_copy/Agents/doctor/

# Runtime data (bind-mounted at /opt/data; must not leak into build context)
data/

# Compose/profile runtime state (bind-mounted; avoid ownership/secret issues)
hermes-config/
runtime/
